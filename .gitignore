# ═══════════════════════════════════════════════════════════════════
#  CommunityPulse — .gitignore
#  Generated with graphify codebase analysis
#  Expo + React Native + Firebase + EAS Build
# ═══════════════════════════════════════════════════════════════════

# ─── Node / NPM ────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ─── Expo ──────────────────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts
.expo-shared/

# ─── Native build output (generated by EAS / expo prebuild) ────────
/android/
/ios/
.kotlin/

# ─── Firebase & Google secrets ─────────────────────────────────────
# google-services.json is intentionally tracked for EAS Cloud Build.
# If your repo is PUBLIC, remove it from here and use EAS Secrets:
#   eas secret:create --scope project --name GOOGLE_SERVICES_JSON --type file --value ./google-services.json
# Then add these back to ignore:
#   google-services.json
#   GoogleService-Info.plist
.firebaserc
firebase.json
serviceAccountKey.json
firestore.rules
firestore.indexes.json

# ─── Environment variables ─────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging

# ─── Code signing & certificates ──────────────────────────────────
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem
*.cert
*.keystore

# ─── Metro bundler ─────────────────────────────────────────────────
.metro-health-check*
.cache/

# ─── Graphify (internal analysis tool — not needed in repo) ────────
graphify-out/

# ─── TypeScript ────────────────────────────────────────────────────
*.tsbuildinfo

# ─── OS generated files ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
ehthumbs.db

# ─── Editor & IDE ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace

# ─── Test & coverage ───────────────────────────────────────────────
coverage/
.nyc_output/
__snapshots__/

# ─── Misc ──────────────────────────────────────────────────────────
*.orig.*
*.map
